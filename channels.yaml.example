# channels.yaml.example
# Copy this to channels.yaml and fill in your ElevenLabs voice IDs.
# Upload credential fields are placeholders — Phase 4 wires them up.
# All other fields are pre-populated and ready to use.

hypothetical-scenarios:
  name: "Hypothetical Scenarios"
  format: storytelling
  voice_id: "REPLACE_WITH_ELEVENLABS_VOICE_ID"
  subreddits:
    - hypothetical
    - AskReddit
    - WouldYouRather
    - changemyview
    - philosophy
  twitter_accounts:
    - WhatIfAlt
    - HypotheticalQ
    - Rainmaker1973
  youtube_client_id: ""
  youtube_client_secret: ""
  instagram_access_token: ""
  quality:
    min_upvotes: 1000
    min_words: 400
    max_words: 1200
    min_likes: 1000

