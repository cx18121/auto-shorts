# channels.yaml.example
# Copy this to channels.yaml and fill in your credentials.
# All other fields are pre-populated with sensible defaults.

hypothetical-scenarios:
  name: "Hypothetical Scenarios"
  format: storytelling
  voice_id: "REPLACE_WITH_ELEVENLABS_VOICE_ID"
  subreddits:
    - hypotheticalsituation
    - WouldYouRather
  twitter_accounts: []  # empty = scrape home feed for organic viral tweets
  youtube_client_id: ""
  youtube_client_secret: ""
  instagram_access_token: ""
  enabled: true
  hashtags:
    - shorts
    - storytime
    - hypothetical
  instagram_user_id: ""  # numeric IG Business account ID from setup-instagram
  youtube_made_for_kids: false
  quality:
    min_upvotes: 300
    min_words: 200
    max_words: 1200
    min_likes: 1000
  generation:
    dur_min: 45   # target narration duration in seconds (lower bound)
    dur_max: 60   # target narration duration in seconds (upper bound)
    word_min: 100 # target word count for generated script (lower bound)
    word_max: 160 # target word count for generated script (upper bound)

relationships:
  name: "Relationships"
  format: storytelling
  voice_id: "REPLACE_WITH_ELEVENLABS_VOICE_ID"
  subreddits:
    - relationship_advice
    - AITAH
    - AmItheAsshole
    - tifu
    - TrueOffMyChest
  twitter_accounts: []
  youtube_client_id: ""
  youtube_client_secret: ""
  instagram_access_token: ""
  enabled: true
  hashtags:
    - shorts
    - storytime
    - relationships
  instagram_user_id: ""
  youtube_made_for_kids: false
  quality:
    min_upvotes: 1000
    min_words: 400
    max_words: 1200
    min_likes: 1000
  generation:
    dur_min: 50
    dur_max: 70
    word_min: 120
    word_max: 180

