    - passive_income
    - investing
  twitter_accounts: []
  youtube_client_id: ""
  youtube_client_secret: ""
  instagram_access_token: ""
  enabled: true
  hashtags:
    - shorts
    - finance
    - hustle
  instagram_user_id: ""  # numeric IG Business account ID from setup-instagram
  quality:
    min_upvotes: 500
    min_words: 200
    max_words: 800
    min_likes: 1000

viral-tweets:
  name: "Viral Tweets"
  format: tweets
  voice_id: "REPLACE_WITH_ELEVENLABS_VOICE_ID"
  subreddits: []
  twitter_accounts: []
  youtube_client_id: ""
  youtube_client_secret: ""
  instagram_access_token: ""
  enabled: true
  hashtags:
    - shorts
    - viral
    - twitter
  instagram_user_id: ""  # numeric IG Business account ID from setup-instagram
  quality:
    min_upvotes: 0
    min_words: 0
    max_words: 9999
    min_likes: 5000
