    dur_min: 40
    dur_max: 55
    word_min: 90
    word_max: 145

viral-tweets:
  name: "Viral Tweets"
  format: tweets
  voice_id: "REPLACE_WITH_ELEVENLABS_VOICE_ID"
  subreddits: []
  twitter_accounts: []
  youtube_client_id: ""
  youtube_client_secret: ""
  instagram_access_token: ""
  enabled: true
  hashtags:
    - shorts
    - viral
    - twitter
  instagram_user_id: ""
  youtube_made_for_kids: false
  quality:
    min_upvotes: 0
    min_words: 0
    max_words: 9999
    min_likes: 5000
  # generation: block is only used by storytelling format channels
