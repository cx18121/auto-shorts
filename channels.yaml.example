# channels.yaml.example
# Copy this to channels.yaml and fill in your ElevenLabs voice IDs.
# All other fields are pre-populated and ready to use.

hypothetical-scenarios:
  name: "Hypothetical Scenarios"
  format: storytelling
  voice_id: "REPLACE_WITH_ELEVENLABS_VOICE_ID"
  subreddits:
    - hypotheticalsituation
    - WouldYouRather
  twitter_accounts: []  # empty = scrape home feed for organic viral tweets
  youtube_client_id: ""
  youtube_client_secret: ""
  instagram_access_token: ""
  enabled: true
  hashtags:
    - shorts
    - storytime
    - hypothetical
  instagram_user_id: ""  # numeric IG Business account ID from setup-instagram
  quality:
    min_upvotes: 300
    min_words: 200
    max_words: 1200
    min_likes: 1000

relationships:
  name: "Relationships"
  format: storytelling
  voice_id: "REPLACE_WITH_ELEVENLABS_VOICE_ID"
  subreddits:
    - relationship_advice
    - AITAH
    - AmItheAsshole
    - tifu
    - TrueOffMyChest
  twitter_accounts: []
  youtube_client_id: ""
  youtube_client_secret: ""
  instagram_access_token: ""
  enabled: true
  hashtags:
    - shorts
    - storytime
    - relationships
  instagram_user_id: ""  # numeric IG Business account ID from setup-instagram
  quality:
    min_upvotes: 1000
    min_words: 400
    max_words: 1200
    min_likes: 1000

finance-hustle:
  name: "Finance & Hustle"
  format: storytelling
  voice_id: "REPLACE_WITH_ELEVENLABS_VOICE_ID"
